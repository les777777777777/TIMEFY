{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and mascot state",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "kairosId": { "type": "string" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "mascotName": { "type": "string" },
        "streak": { "type": "number" },
        "balance": { "type": "number" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "kairosId", "name", "mascotName", "streak", "balance"]
    },
    "Friendship": {
      "title": "Friendship",
      "description": "Connection between two users",
      "type": "object",
      "properties": {
        "userIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userIds", "createdAt"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "Quick support signals between friends",
      "type": "object",
      "properties": {
        "fromUserId": { "type": "string" },
        "toUserId": { "type": "string" },
        "type": { "type": "string", "enum": ["well_done", "keep_going", "rest"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUserId", "toUserId", "type", "timestamp"]
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "text", "completed", "createdAt"]
    },
    "Habit": {
      "title": "Habit",
      "description": "Items for wellness or routine",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "type": { "type": "string", "enum": ["wellness", "routine"] },
        "icon": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "text", "completed", "type", "createdAt"]
    },
    "Alarm": {
      "title": "Alarm",
      "description": "User set alarms",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "time": { "type": "string" },
        "category": { "type": "string" },
        "enabled": { "type": "boolean" },
        "days": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "time", "enabled"]
    },
    "Event": {
      "title": "Event",
      "description": "Calendar events",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "location": { "type": "string" },
        "type": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "startTime", "endTime"]
    },
    "Achievement": {
      "title": "Achievement",
      "description": "Unlocked user achievements",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "unlockedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "unlockedAt"]
    },
    "ProgressHistory": {
      "title": "ProgressHistory",
      "description": "Daily balance records for stats mapping",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "value": { "type": "number" }
      },
      "required": ["userId", "date", "value"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "User profiles"
    },
    "friendships": {
      "schema": "Friendship",
      "description": "Connections between users"
    },
    "interactions": {
      "schema": "Interaction",
      "description": "Transient support signals"
    },
    "tasks": {
      "schema": "Task",
      "description": "User tasks"
    },
    "habits": {
      "schema": "Habit",
      "description": "User wellness rituals and routines"
    },
    "alarms": {
      "schema": "Alarm",
      "description": "User alarms"
    },
    "events": {
      "schema": "Event",
      "description": "User calendar events"
    },
    "achievements": {
      "schema": "Achievement",
      "description": "Unlocked achievements"
    },
    "progressHistory": {
      "schema": "ProgressHistory",
      "description": "Daily timeline records of user time balances"
    }
  }
}
